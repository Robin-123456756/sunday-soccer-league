generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  scheduled
  in_progress
  completed
  postponed
}

enum LineupType {
  starter
  bench
}

enum CardType {
  yellow
  red
  second_yellow_red
}

enum ExportType {
  player_details
  team_players
  discipline_report
  appearance_report
}

enum ExportFormat {
  csv
  xlsx
}

enum ExportStatus {
  pending
  completed
  failed
}

model Team {
  id             String        @id @default(cuid())
  name           String        @unique
  shortName      String?
  primaryColor   String?
  secondaryColor String?
  homeVenue      String?
  players        Player[]
  homeMatches    Match[]       @relation("HomeTeam")
  awayMatches    Match[]       @relation("AwayTeam")
  lineups        MatchLineup[]
  substitutions  Substitution[]
  cardEvents     CardEvent[]
  uploads        TeamSheetUpload[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Player {
  id                 String        @id @default(cuid())
  teamId             String
  fullName           String
  jerseyNumber       Int?
  position           String?
  registrationNumber String?
  isActive           Boolean       @default(true)
  team               Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  lineups            MatchLineup[]
  playerOffSubs      Substitution[] @relation("PlayerOff")
  playerOnSubs       Substitution[] @relation("PlayerOn")
  cardEvents         CardEvent[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([teamId])
}

model Referee {
  id          String          @id @default(cuid())
  fullName    String
  phone       String?
  email       String?
  level       String?
  isActive    Boolean         @default(true)
  matches     Match[]
  reports     RefereeReport[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Matchday {
  id          String   @id @default(cuid())
  name        String
  roundNumber Int?
  seasonLabel String?
  matches     Match[]
  createdAt   DateTime @default(now())
}

model Match {
  id                String           @id @default(cuid())
  matchdayId        String?
  matchDate         DateTime
  kickoffTimeLabel  String?
  venue             String?
  homeTeamId        String
  awayTeamId        String
  homeJerseyColor   String?
  awayJerseyColor   String?
  refereeId         String?
  status            MatchStatus      @default(scheduled)
  homeScore         Int?
  awayScore         Int?
  matchday          Matchday?        @relation(fields: [matchdayId], references: [id], onDelete: SetNull)
  homeTeam          Team             @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam          Team             @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  referee           Referee?         @relation(fields: [refereeId], references: [id], onDelete: SetNull)
  lineups           MatchLineup[]
  substitutions     Substitution[]
  cardEvents        CardEvent[]
  refereeReport     RefereeReport?
  uploads           TeamSheetUpload[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([matchdayId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([refereeId])
}

model MatchLineup {
  id         String     @id @default(cuid())
  matchId     String
  teamId      String
  playerId    String
  lineupType  LineupType
  isCaptain   Boolean    @default(false)
  match       Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team        Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player      Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@unique([matchId, playerId])
  @@index([matchId, teamId])
}

model Substitution {
  id          String    @id @default(cuid())
  matchId      String
  teamId       String
  playerOffId  String
  playerOnId   String
  minute       Int
  reason       String?
  match        Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team         Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerOff    Player    @relation("PlayerOff", fields: [playerOffId], references: [id], onDelete: Restrict)
  playerOn     Player    @relation("PlayerOn", fields: [playerOnId], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())

  @@index([matchId, teamId])
}

model CardEvent {
  id           String    @id @default(cuid())
  matchId       String
  teamId        String
  playerId      String
  cardType      CardType
  minute        Int
  reason        String
  refereeNote   String?
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player        Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([matchId, teamId])
  @@index([playerId])
}

model RefereeReport {
  id                         String    @id @default(cuid())
  matchId                    String    @unique
  refereeId                  String
  generalComment             String?
  timeManagementObservation  String?
  dressCodeObservation       String?
  organizationObservation    String?
  conductObservation         String?
  incidents                  String?
  match                      Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  referee                    Referee    @relation(fields: [refereeId], references: [id], onDelete: Restrict)
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt

  @@index([refereeId])
}

model TeamSheetUpload {
  id               String    @id @default(cuid())
  matchId           String
  teamId            String
  fileName          String
  fileUrl           String
  fileType          String
  uploadedByUserId  String?
  uploadedAt        DateTime  @default(now())
  match             Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team              Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([matchId, teamId])
}

model ExportJob {
  id                String       @id @default(cuid())
  requestedByUserId String
  exportType        ExportType
  fileFormat        ExportFormat
  filtersJson       String?
  fileUrl           String?
  status            ExportStatus @default(pending)
  createdAt         DateTime     @default(now())
}
